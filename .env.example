# ---------- Backend (server.js) — las API keys viven SOLO aquí ----------
NODE_ENV=production
PORT=3000

# OpenAI (ChatGPT)
OPENAI_API_KEY=sk-...
# Opcionales (valores por defecto):
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_WEB=gpt-4o-search-preview

# NocoDB (sincronización del estado)
NOCO_TOKEN=nc_pat_...
# Puede ser la URL del dashboard (con base/tabla/vista) o el host raíz.
NOCO_URL=https://prueba-nocodb.urdzg3.easypanel.host/...
# Opcional: forzar el ID de tabla si no se puede deducir de NOCO_URL
# NOCO_TABLE_ID=my6a4d44cc63yyv

# ---------- Frontend (Vite) ----------
# "local" (navegador) o "nocodb" (sincroniza vía el backend)
VITE_DATA_MODE=nocodb
